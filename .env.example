# ═══════════════════════════════════════════════════════════
# TRADING BOT PLATFORM — Variables de entorno
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env a git (está en .gitignore)
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────
# APP
# ─────────────────────────────────────────
ENV=development           # development | production
DEBUG=true

# ─────────────────────────────────────────
# BASE DE DATOS (PostgreSQL)
# ─────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=tradingbot
POSTGRES_USER=admin
POSTGRES_PASSWORD=CAMBIA_ESTA_PASSWORD

# Construidas a partir de las anteriores (sin interpolación — rellena manualmente)
# Para escala >150 usuarios concurrentes, apuntar a PgBouncer en lugar de PostgreSQL directo:
#   host=pgbouncer  port=6432
# En desarrollo local o con pocos usuarios, puedes seguir usando postgres:5432
DATABASE_URL=postgresql+asyncpg://admin:CAMBIA_ESTA_PASSWORD@pgbouncer:6432/tradingbot
DATABASE_URL_SYNC=postgresql+psycopg2://admin:CAMBIA_ESTA_PASSWORD@pgbouncer:6432/tradingbot

# ─────────────────────────────────────────
# PGBOUNCER (proxy de conexiones PostgreSQL)
# ─────────────────────────────────────────
# Requiere crear docker/pgbouncer/userlist.txt con el hash md5 de la contraseña:
#   python3 -c "import hashlib; print('md5' + hashlib.md5(b'PASSWORD+USER').hexdigest())"
# El archivo docker/pgbouncer/pgbouncer.ini ya está configurado para producción.
# No es necesario definir variables adicionales — usa POSTGRES_USER / POSTGRES_PASSWORD.

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CAMBIA_ESTA_PASSWORD_REDIS

# DB 0: cache general (precios, balances)
# DB 1: broker de tareas Celery
# DB 2: resultados de tareas Celery
# Las URLs se construyen automáticamente con la contraseña

# ─────────────────────────────────────────
# AUTENTICACIÓN (JWT)
# ─────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIA_ESTE_SECRET_MINIMO_32_CARACTERES
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# ENCRIPTACIÓN (API keys de exchanges en DB)
# ─────────────────────────────────────────
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=GENERAR_CON_FERNET

# ─────────────────────────────────────────
# EXCHANGES — URLs base
# Las API keys se guardan por cuenta en la DB (encriptadas)
# ─────────────────────────────────────────
BINGX_BASE_URL=https://open-api.bingx.com
BITUNIX_BASE_URL=https://api.bitunix.com

# ─────────────────────────────────────────
# NOTIFICACIONES
# ─────────────────────────────────────────
# Telegram: crear bot con @BotFather → obtener token
# Token legacy: se mantiene como fallback si no se configuran los tokens específicos.
TELEGRAM_BOT_TOKEN=
# Bot para notificaciones de IA y trades reales (TRADING BOT NOTIFIER).
TELEGRAM_TRADING_BOT_TOKEN=
# Bot para bots solo alertas / Telegram-only (QUANTUM BOT NOTIFIER).
TELEGRAM_QUANTUM_BOT_TOKEN=
# Grupo y topic de Telegram donde QUANTUM BOT NOTIFIER envia las senales de webhook.
TELEGRAM_QUANTUM_GROUP_CHAT_ID=
TELEGRAM_QUANTUM_THREAD_ID=13
TELEGRAM_CHAT_ID=

# Discord: Servidor → Ajustes del canal → Integraciones → Webhooks
DISCORD_WEBHOOK_URL=

# Nivel de notificaciones Telegram: "essential" (solo trades + críticos) o "verbose" (todo)
TELEGRAM_NOTIFY_LEVEL=essential

# ─────────────────────────────────────────
# TRADINGVIEW (seguridad webhooks)
# ─────────────────────────────────────────
# IPs oficiales de TradingView (actualizar en: tradingview.com/webhook/ips)
TRADINGVIEW_ALLOWED_IPS=52.89.214.238,34.212.75.30,54.70.159.135,54.218.53.128,34.212.75.30

# ─────────────────────────────────────────
# CELERY BEAT (tareas programadas)
# ─────────────────────────────────────────
# Días de retención de logs (cleanup diario)
CLEANUP_LOGS_DAYS=30

# ─────────────────────────────────────────
# FLOWER (monitoreo Celery — solo dev)
# ─────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=CAMBIA_ESTA_PASSWORD

# ─────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────
VITE_API_URL=http://localhost:8100
VITE_WS_URL=ws://localhost:8100
CORS_ORIGINS=http://localhost:5173,http://localhost:5274,http://localhost:80,http://localhost:8080

# ─────────────────────────────────────────
# LLM LOCAL (Ollama / vLLM) — opcional
# ─────────────────────────────────────────
# El asistente y los tips del Scanner Live pueden usar un modelo local expuesto
# con API compatible OpenAI. En producción se suele usar un túnel SSH al host
# que ejecuta Ollama (ver servicio ollama-bridge en docker-compose.yml).
LOCAL_LLM_ENABLED=false
LOCAL_LLM_URL=http://ollama-bridge:11434/v1
LOCAL_LLM_MODEL=mistral:7b
LOCAL_LLM_MODEL_ASSISTANT=qwen2.5:7b
LOCAL_LLM_MODEL_HEAVY=mixtral:8x7b
ASSISTANT_USE_LOCAL_LLM=true

# ─────────────────────────────────────────
# REGISTRO DE USUARIOS
# ─────────────────────────────────────────
# false en producción — usa scripts/create-admin.py para el primer usuario
ALLOW_REGISTRATION=false

# ─────────────────────────────────────────
# DESARROLLADOR / SUPER-ADMIN
# ─────────────────────────────────────────
# Lista separada por comas de usernames con acceso completo al asistente
# (IA Engine, administración del sistema, gestión de usuarios, etc.)
DEVELOPER_USERNAMES=Marci526
